  "item": [
    {
      "name": "Get all users",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Response time less than 500ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(500);\r",
              "});\r",
              "\r",
              "pm.test(\"Email contains @\", function () {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.expect(jsonData[0].email).to.include(\"@\");\r",
              "});\r",
              "\r",
              "pm.test(\"The response is an array\", function () {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.expect(jsonData).to.be.an(\"array\");\r",
              "});\r",
              "\r",
              "pm.test(\"The object has expected fields\", function () {\r",
              "    const jsonData = pm.response.json();\r",
              "\r",
              "    pm.expect(jsonData[0]).to.have.property(\"id\");\r",
              "    pm.expect(jsonData[0]).to.have.property(\"name\");\r",
              "    pm.expect(jsonData[0]).to.have.property(\"email\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
